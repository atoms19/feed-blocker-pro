{
  "manifest_version": 3,
  "name": "Feed Blocker Pro",
  "version": "1.0",
  "description": "Removes distracting feeds from websites.",
 
  "permissions": [],
  "host_permissions": ["<all_urls>"],

"web_accessible_resources": [
    {
"resources": ["*.js", "lib/*.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["entry.js"],
      "run_at": "document_start"
    }
  ]
}
